# ── Model Provider ─────────────────────────────────────────────────────────────
# Set to "ollama" for local/free or "gemini" for cloud
MODEL_PROVIDER=gemini

# ── Gemini (cloud) ─────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── Ollama (local, free, unlimited) ────────────────────────────────────────────
# Install: https://ollama.com/download
# Pull model: ollama pull llama3.2
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── GitHub (optional but recommended) ──────────────────────────────────────────
# Optional but recommended. Raises GitHub API rate limit from 60 to 5000 req/hr.
# Create at: https://github.com/settings/tokens — no scopes needed for public repos.
GITHUB_TOKEN=

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change_this_to_a_long_random_string
FLASK_PORT=5000
FLASK_DEBUG=false
